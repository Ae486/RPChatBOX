{
  "case_id": "setup.rejected_proposal.back_to_discussion.v1",
  "title": "After a rejected proposal the agent should continue discussion instead of reproposing commit",
  "scope": "setup",
  "category": "commit_recovery",
  "tags": ["mvp", "deterministic", "setup-v2", "cognitive-runtime"],
  "runtime_target": {
    "mode": "in_process",
    "entrypoint": "setup_graph_runner.run_turn",
    "graph_id": "setup_v2",
    "stream": false
  },
  "input": {
    "request": {
      "workspace_id": "case-rejected-proposal-001",
      "target_step": "story_config",
      "user_prompt": "再试一次，如果可以的话就 review。",
      "history": [],
      "model_id": "model-eval",
      "provider_id": "provider-eval"
    },
    "workspace_seed": {
      "story_id": "story-case-rejected-proposal-001",
      "mode": "longform",
      "current_step": "story_config",
      "rejected_proposals": [
        {
          "step_id": "story_config",
          "target_draft_refs": ["draft:story_config"],
          "reason": "The previous proposal was rejected."
        }
      ]
    },
    "env_overrides": {}
  },
  "preconditions": {},
  "expected": {
    "deterministic_assertions": [
      {
        "assertion_id": "finish_is_continue_discussion",
        "source": "runtime_result",
        "type": "equals",
        "path": "finish_reason",
        "expected": "continue_discussion",
        "severity": "error"
      },
      {
        "assertion_id": "warnings_include_commit_blocked",
        "source": "runtime_result",
        "type": "contains",
        "path": "warnings",
        "expected": "commit_proposal_blocked",
        "severity": "error"
      },
      {
        "assertion_id": "completion_guard_requires_discussion",
        "source": "runtime_result",
        "type": "equals",
        "path": "structured_payload.completion_guard.reason",
        "expected": "discussion_continues_without_commit",
        "severity": "error"
      },
      {
        "assertion_id": "latest_workspace_proposal_stays_rejected",
        "source": "workspace_truth",
        "type": "equals",
        "path": "commit_proposals[-1].status",
        "expected": "rejected",
        "severity": "error"
      }
    ],
    "subjective_hooks": []
  },
  "trace_hooks": {
    "capture_runtime_events": true,
    "capture_graph_debug": true,
    "capture_workspace_before_after": true
  },
  "repeat": {
    "count": 1,
    "stop_on_first_hard_failure": false
  },
  "baseline": {
    "compare_by": ["finish_reason", "warnings", "assertion_pass_rate", "reason_codes", "outcome_chain"],
    "baseline_tags": ["main"]
  },
  "metadata": {}
}

