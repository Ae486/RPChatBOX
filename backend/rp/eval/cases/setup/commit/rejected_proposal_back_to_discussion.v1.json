{
  "case_id": "setup.rejected_proposal.back_to_discussion.v1",
  "title": "Explicit reproposal after rejection creates a warning-backed commit proposal",
  "scope": "setup",
  "category": "commit_recovery",
  "tags": ["mvp", "deterministic", "setup-v2", "cognitive-runtime"],
  "runtime_target": {
    "mode": "in_process",
    "entrypoint": "setup_graph_runner.run_turn",
    "graph_id": "setup_v2",
    "stream": false
  },
  "input": {
    "request": {
      "workspace_id": "case-rejected-proposal-001",
      "target_step": "story_config",
      "user_prompt": "再试一次，如果可以的话就 review。",
      "history": [],
      "model_id": "model-eval",
      "provider_id": "provider-eval"
    },
    "workspace_seed": {
      "story_id": "story-case-rejected-proposal-001",
      "mode": "longform",
      "current_step": "story_config",
      "rejected_proposals": [
        {
          "step_id": "story_config",
          "target_draft_refs": ["draft:story_config"],
          "reason": "The previous proposal was rejected."
        }
      ]
    },
    "env_overrides": {}
  },
  "preconditions": {},
  "expected": {
    "deterministic_assertions": [
      {
        "assertion_id": "finish_is_completed_text",
        "source": "runtime_result",
        "type": "equals",
        "path": "finish_reason",
        "expected": "completed_text",
        "severity": "error"
      },
      {
        "assertion_id": "warnings_include_commit_warning",
        "source": "runtime_result",
        "type": "contains",
        "path": "warnings",
        "expected": "previous_proposal_rejected",
        "severity": "error"
      },
      {
        "assertion_id": "latest_workspace_proposal_is_pending",
        "source": "workspace_truth",
        "type": "equals",
        "path": "commit_proposals[-1].status",
        "expected": "pending_review",
        "severity": "error"
      }
    ],
    "subjective_hooks": [],
    "expected_reason_codes": [
      "controller.commit_proposal_warned"
    ],
    "expected_outcome_chain": {
      "transcript_status": "not_applicable",
      "truth_status": "pass",
      "readiness_status": "warn"
    },
    "expected_recommended_next_action": "surface_commit_readiness_warnings_to_user_review"
  },
  "trace_hooks": {
    "capture_runtime_events": true,
    "capture_graph_debug": true,
    "capture_workspace_before_after": true
  },
  "repeat": {
    "count": 1,
    "stop_on_first_hard_failure": false
  },
  "baseline": {
    "compare_by": ["finish_reason", "warnings", "assertion_pass_rate", "reason_codes", "outcome_chain"],
    "baseline_tags": ["main"]
  },
  "metadata": {}
}

