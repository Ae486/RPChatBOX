{
  "case_id": "retrieval.search.archival_source_filter_policy.v1",
  "title": "Archival search should expose source metadata filters through query trace and hits",
  "scope": "retrieval",
  "category": "retrieval_ready",
  "tags": ["policy", "deterministic", "retrieval-core", "archival-filter"],
  "runtime_target": {
    "mode": "in_process",
    "entrypoint": "minimal_retrieval_ingestion_service.ingest_commit",
    "graph_id": "retrieval_core",
    "stream": false
  },
  "input": {
    "request": {
      "workspace_id": "case-retrieval-archival-source-filter-001",
      "query": {
        "query_kind": "archival",
        "text_query": "filter policy moon archive",
        "domains": ["world_rule"],
        "top_k": 3,
        "filters": {
          "source_types": ["foundation_entry"],
          "source_origins": ["setup_workspace"]
        },
        "search_kind": "chunks",
        "rerank": false
      }
    },
    "workspace_seed": {
      "story_id": "story-case-retrieval-archival-source-filter-001",
      "mode": "longform",
      "current_step": "foundation",
      "drafts": {
        "foundation": {
          "entries": [
            {
              "entry_id": "filter_policy_archive_rule",
              "domain": "world",
              "path": "world.filter_policy_archive_rule",
              "title": "Filter Policy Archive Rule",
              "tags": ["filter", "policy"],
              "source_refs": [],
              "content": {
                "summary": "The moon archive filter policy keeps source metadata searchable."
              }
            }
          ]
        }
      },
      "accepted_proposals": [
        {
          "step_id": "foundation",
          "target_draft_refs": ["foundation:filter_policy_archive_rule"],
          "reason": "freeze source filter fixture"
        }
      ]
    },
    "env_overrides": {}
  },
  "preconditions": {},
  "expected": {
    "deterministic_assertions": [
      {
        "assertion_id": "finish_is_retrieval_completed",
        "source": "retrieval_result",
        "type": "equals",
        "path": "finish_reason",
        "expected": "retrieval_completed",
        "severity": "error"
      },
      {
        "assertion_id": "query_hits_exist",
        "source": "retrieval_result",
        "type": "count_gte",
        "path": "query_result.hits",
        "expected": 1,
        "severity": "error"
      },
      {
        "assertion_id": "hit_source_type_is_foundation_entry",
        "source": "retrieval_result",
        "type": "equals",
        "path": "query_result.hits[0].metadata.source_type",
        "expected": "foundation_entry",
        "severity": "error"
      },
      {
        "assertion_id": "hit_source_origin_is_setup_workspace",
        "source": "retrieval_result",
        "type": "equals",
        "path": "query_result.hits[0].metadata.source_origin",
        "expected": "setup_workspace",
        "severity": "error"
      },
      {
        "assertion_id": "trace_records_source_type_filter",
        "source": "retrieval_result",
        "type": "equals",
        "path": "query_result.trace.filters_applied.filters.source_types[0]",
        "expected": "foundation_entry",
        "severity": "error"
      }
    ],
    "subjective_hooks": []
  },
  "trace_hooks": {
    "capture_runtime_events": false,
    "capture_graph_debug": false,
    "capture_workspace_before_after": true
  },
  "repeat": {
    "count": 1,
    "stop_on_first_hard_failure": false
  },
  "baseline": {
    "compare_by": ["finish_reason", "assertion_pass_rate"],
    "baseline_tags": ["main"]
  },
  "metadata": {}
}
